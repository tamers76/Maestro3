# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ============================================================================
# Postgres (PRIMARY database + pgvector). REQUIRED at startup.
# Connect as the least-privilege `maestro` role that OWNS the app objects —
# NEVER the `postgres` superuser. The pgvector extension is created once by a
# superuser; the app only USEs it.
#
#   CREATE ROLE maestro LOGIN PASSWORD '<strong>';
#   GRANT CONNECT ON DATABASE maestronexus TO maestro;
#   CREATE SCHEMA IF NOT EXISTS maestro AUTHORIZATION maestro;
#   -- as superuser, once: CREATE EXTENSION IF NOT EXISTS vector;
# ============================================================================
DATABASE_URL=postgresql://maestro:<strong>@127.0.0.1:5432/maestronexus
# Optional discrete fallbacks (used only if DATABASE_URL is empty):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=maestro
# PGPASSWORD=<strong>
# PGDATABASE=maestronexus
# Maestro tables live in a dedicated schema (default `maestro_v1`) so they never
# collide with other apps sharing this database. Override if needed:
# APP_DB_SCHEMA=maestro_v1
# HNSW_EF_SEARCH=200   # raise for higher scoped-recall at some latency cost

# Neo4j (SECONDARY — graph projection only; OPTIONAL). Traversal/visualization
# degrades if down, but entity reads/writes never depend on it.
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embedding model used for RAG (must match the vector(1536) column dimension)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
