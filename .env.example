# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# ============================================================================
# Postgres (PRIMARY database + pgvector). REQUIRED at startup.
# Connect as the least-privilege `maestro` role that OWNS the app objects —
# NEVER the `postgres` superuser. The pgvector extension is created once by a
# superuser; the app only USEs it.
#
#   CREATE ROLE maestro LOGIN PASSWORD '<strong>';
#   GRANT CONNECT ON DATABASE maestronexus TO maestro;
#   CREATE SCHEMA IF NOT EXISTS maestro AUTHORIZATION maestro;
#   -- as superuser, once: CREATE EXTENSION IF NOT EXISTS vector;
# ============================================================================
DATABASE_URL=postgresql://maestro:<strong>@127.0.0.1:5432/maestronexus
# Optional discrete fallbacks (used only if DATABASE_URL is empty):
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=maestro
# PGPASSWORD=<strong>
# PGDATABASE=maestronexus
# Maestro tables live in a dedicated schema (default `maestro_v1`) so they never
# collide with other apps sharing this database. Override if needed:
# APP_DB_SCHEMA=maestro_v1
# HNSW_EF_SEARCH=200   # raise for higher scoped-recall at some latency cost

# Neo4j (SECONDARY — graph projection only; OPTIONAL). Traversal/visualization
# degrades if down, but entity reads/writes never depend on it.
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Embedding model used for RAG (must match the vector(1536) column dimension)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# HeyGen API Key (Settings → API at https://app.heygen.com)
# Used by Layer 4 video render (POST /v3/videos). Never commit the real value.
HEYGEN_API_KEY=

# ============================================================================
# Authentication / RBAC. REQUIRED for real auth.
# JWT_SECRET signs session tokens — set a long random value in production. If it
# is unset, the server falls back to an INSECURE dev secret and logs a warning.
# ============================================================================
JWT_SECRET=
# Token lifetime (e.g. 1h, 7d). Defaults to 7d.
# JWT_EXPIRES_IN=7d

# First-run admin seeding. On startup, if both are set, an admin account is
# ensured (created if missing; password kept in sync). Without them, and with no
# users present, the server logs a warning and creates nothing.
MAESTRO_ADMIN_EMAIL=
MAESTRO_ADMIN_PASSWORD=
# MAESTRO_ADMIN_NAME=Administrator

# Default DEV accounts (INSECURE — local development only). When enabled, a fresh
# DB is seeded with admin/admin, prof/prof, prof2/prof2, prof3/prof3, prof4/prof4,
# and student/student. Enabled by default unless NODE_ENV=production. Force with
# SEED_DEV_USERS=1 or disable with SEED_DEV_USERS=0.
# SEED_DEV_USERS=1
